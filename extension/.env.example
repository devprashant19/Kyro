# ── Local Development ─────────────────────────────────────────────────────────
# URL for backend API (Default: http://localhost:8000)
VITE_BACKEND_URL=http://localhost:8000

# Dashboard URL (Default: http://localhost:5173)
VITE_DASHBOARD_URL=http://localhost:5173

# ── Production (Cloud Deployment) ─────────────────────────────────────────────
# After deploying to Render, replace with your actual Render service URL:
# VITE_BACKEND_URL=https://kyro-api.onrender.com

# After deploying to Vercel, replace with your actual Vercel URL:
# VITE_DASHBOARD_URL=https://kyro-dashboard.vercel.app

# ── Clerk Authentication (Required) ───────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
