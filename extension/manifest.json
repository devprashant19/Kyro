{
  "manifest_version": 3,
  "name": "Kyro Context Tracker",
  "version": "1.0.0",
  "description": "Your AI That Never Forgets. Automatically captures context across Github, Medium, YouTube, and AI platforms.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webNavigation",
    "cookies",
    "alarms"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "kyro-manual-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "MacCtrl+Shift+K"
      },
      "description": "Capture highlighted text to Kyro MemoryOS"
    }
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Kyro"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://medium.com/*",
        "https://dev.to/*",
        "https://www.youtube.com/*",
        "https://*.wikipedia.org/*"
      ],
      "js": [
        "src/content/index.ts"
      ]
    },
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "src/content/github.ts"
      ]
    },
    {
      "matches": [
        "https://www.google.com/search?*",
        "https://www.bing.com/search?*"
      ],
      "js": [
        "src/content/search.ts"
      ]
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/content/chatgpt.ts"
      ]
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "src/content/claude.ts"
      ]
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "src/content/gemini.ts"
      ]
    },
    {
      "matches": [
        "https://www.perplexity.ai/*"
      ],
      "js": [
        "src/content/perplexity.ts"
      ]
    }
  ]
}