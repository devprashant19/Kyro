{
  "manifest_version": 3,
  "name": "Kyro Context Tracker",
  "version": "1.0.0",
  "description": "Your AI That Never Forgets. Automatically captures context across Github, Medium, YouTube, and AI platforms.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Kyro"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*", "https://medium.com/*", "https://dev.to/*", "https://www.youtube.com/*", "https://chat.openai.com/*", "https://gemini.google.com/*", "https://claude.ai/*"],
      "js": ["src/content/index.ts"]
    }
  ]
}
